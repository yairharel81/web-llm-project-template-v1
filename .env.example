# ─── App ────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change-me-to-a-long-random-string
FRONTEND_URL=http://localhost:5173

# ─── Database (PostgreSQL) ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://appuser:apppassword@localhost:5432/appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword
POSTGRES_DB=appdb

# ─── Redis (SSE pub/sub) ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# ─── Gemini AI ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash
USE_MOCK_GEMINI=true         # true = use fake service locally

# ─── Brevo (Email) ───────────────────────────────────────────────────────────
BREVO_API_KEY=your-brevo-api-key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Your App
USE_MOCK_EMAIL=true          # true = log emails to console locally

# ─── Google Cloud Storage ────────────────────────────────────────────────────
GCS_BUCKET_NAME=your-gcs-bucket
GCS_PROJECT_ID=your-gcp-project-id
USE_MOCK_STORAGE=true        # true = use local filesystem locally

# ─── Firestore ───────────────────────────────────────────────────────────────
FIRESTORE_PROJECT_ID=your-gcp-project-id
FIRESTORE_DATABASE=(default)
USE_MOCK_FIRESTORE=true      # true = use in-memory store locally
